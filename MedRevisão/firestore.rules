rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields: uid, email, displayName, photoURL, createdAt, settings
    //
    // Collection: users/{userId}/subjects
    // Fields: name, color, icon, createdAt
    //
    // Collection: users/{userId}/topics
    // Fields: name, subjectId, lastReviewDate, nextReviewDate, interval, easinessFactor, repetitions, createdAt
    //
    // Collection: users/{userId}/studySessions
    // Fields: topicId, subjectId, date, questionsCount, correctCount, studyTimeMinutes
    //
    // Collection: users/{userId}/calendarEvents
    // Fields: title, description, start, end, googleEventId
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "lucas1renck2melo@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid is string && 
             (data.email == null || data.email is string) &&
             (data.settings == null || data.settings is map);
    }

    function isValidSubject(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidTopic(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.subjectId is string;
    }

    function isValidStudySession(data) {
      return data.topicId is string && data.subjectId is string &&
             data.questionsCount is number && data.correctCount is number;
    }

    function isValidCalendarEvent(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.start is string && data.end is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());

      match /subjects/{subjectId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidSubject(request.resource.data);
        allow update: if isOwner(userId) && isValidSubject(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /topics/{topicId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidTopic(request.resource.data);
        allow update: if isOwner(userId) && isValidTopic(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /studySessions/{sessionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidStudySession(request.resource.data);
        allow update: if isOwner(userId) && isValidStudySession(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /calendarEvents/{eventId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidCalendarEvent(request.resource.data);
        allow update: if isOwner(userId) && isValidCalendarEvent(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /secrets/{secretId} {
        allow read, write: if false; // Only accessible via Admin SDK
      }
    }
  }
}
